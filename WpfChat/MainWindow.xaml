<Window x:Class="WpfChat.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfChat"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal"
                    Grid.Row="0" 
                    Margin="0,0,0,8" 
                    VerticalAlignment="Center">
            <TextBlock VerticalAlignment="Center"
                       Text="API Key:" />
            <TextBox x:Name="ApiKeyTextBox"
                     Width="260" />
            <Button x:Name="LoadModelsButton" 
                    Content="Load Models" 
                    Click="LoadModelsButton_Click" />
            <TextBlock VerticalAlignment="Center"
                       Margin="12,0,0,0"
                       Text="Model:" />
            <ComboBox x:Name="ModelsComboBox"
                      Width="250"
                      DisplayMemberPath="." />
        </StackPanel>

        <ListBox x:Name="MessagesListBox" Grid.Row="1" Margin="0,0,0,8" />

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    VerticalAlignment="Bottom">
            <TextBox x:Name="InputTextBox"
                     Width="600"
                     Height="28"
                     KeyDown="InputTextBox_KeyDown" />
            <Button x:Name="SendButton"
                    Content="Send"
                    Width="100"
                    Click="SendButton_Click" />
        </StackPanel>
    </Grid>
</Window>
